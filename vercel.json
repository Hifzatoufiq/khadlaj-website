{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "bundle-v5.js", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "video/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/video/(.*)", "dest": "/video/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/bundle-v5.js", "dest": "/bundle-v5.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
